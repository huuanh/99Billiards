{
  "name": "99billiards",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace @99billiards/web run dev",
    "dev:admin": "npm --workspace @99billiards/admin run dev",
    "build": "npm run build:web && npm run build:admin",
    "build:web": "npm --workspace @99billiards/web run build",
    "build:admin": "npm --workspace @99billiards/admin run build",
    "lint": "npm --workspace @99billiards/web run lint && npm --workspace @99billiards/admin run lint",
    "seed": "npm --workspace @99billiards/db run seed",
    "check:env": "tsx scripts/check-env.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/s3-request-presigner": "^3.948.0",
    "@playwright/test": "^1.57.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.1.3",
    "mongoose": "^9.0.1",
    "tsx": "^4.21.0",
    "zod": "^4.2.1"
  }
}
